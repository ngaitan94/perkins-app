---
import SectionPhase from '../components/SectionPhase.astro';
---

<section class="section section-cta" id="empezar">
	<div class="container">
		<div class="cta-banner" data-reveal>
			<SectionPhase phase="accion" />
			<h2 class="cta-banner__title">¿Listo pa tu primera paletiada?</h2>
			<p class="cta-banner__lead">
				Crea tu cuenta en menos de un minuto. Pide como vioh o trae como Perkin en tu comuna.
			</p>
			<div class="cta-banner__actions">
				<a href="/registro" class="btn btn-primary">Pedir una paletiada</a>
				<a href="/registro?role=perkin" class="btn btn-secondary">¿Te pegai la misión?</a>
			</div>
			<p class="cta-banner__note muted">Sin tarjeta para empezar · Planes premium cuando quieras escalar</p>
		</div>
	</div>
</section>
