---
import SectionPhase from '../components/SectionPhase.astro';
---

<section class="hero section-dark" id="inicio">
	<div class="hero-bg" aria-hidden="true">
		<div class="hero-orb hero-orb--1"></div>
		<div class="hero-orb hero-orb--2"></div>
		<div class="hero-orb hero-orb--3"></div>
	</div>
	<div class="container hero-grid">
		<div class="hero-copy">
			<SectionPhase phase="atencion" />
			<p class="badge badge-glow hero-badge">Paletiadas entre viohs · Chile</p>
			<h1 class="hero-title"><span class="highlight">Vioh que pide</span>, Perkin que trae</h1>
			<p class="hero-lead">
				Pa hacer lucas o pa salir del paso: el vioh pide, el perkin se pone la capa y hace la paletiada.
				Todos parten de perkin, aspiran a ser la ficha máxima. De perkin a ser la ficha máxima.
			</p>
			<div class="hero-social" aria-label="Comunidad Perkins en Chile">
				<div class="hero-social-avatars" aria-hidden="true">
					<span class="hero-avatar" style="--avatar-bg: linear-gradient(135deg, #10b981, #059669)">MC</span>
					<span class="hero-avatar" style="--avatar-bg: linear-gradient(135deg, #6366f1, #4338ca)">JP</span>
					<span class="hero-avatar" style="--avatar-bg: linear-gradient(135deg, #f59e0b, #d97706)">TR</span>
					<span class="hero-avatar" style="--avatar-bg: linear-gradient(135deg, #ec4899, #be185d)">CF</span>
					<span class="hero-avatar hero-avatar--more">+380</span>
				</div>
				<div class="hero-social-copy">
					<p class="hero-social-headline">
						<strong>+380 viohs</strong> ya tiraron la misión en la RM
					</p>
					<p class="hero-social-meta">
						<span class="hero-social-stars" aria-label="4.9 de 5">★★★★★</span>
						<span>4.9 ficha promedio</span>
						<span class="hero-social-sep" aria-hidden="true">·</span>
						<span>Pagos con Mercado Pago</span>
					</p>
				</div>
			</div>
			<div class="hero-actions">
				<a href="/registro" class="btn btn-primary">Pedir una paletiada</a>
				<a href="/registro?role=perkin" class="btn btn-secondary" title="Hacer la paletiada y cumplir la misión">¿Te pegai la misión?</a>
			</div>
			<div class="hero-stats" aria-label="Métricas de la comunidad">
				<div class="hero-stat">
					<span class="hero-stat-value">340+</span>
					<span class="hero-stat-label">Paletiadas cumplidas</span>
				</div>
				<div class="hero-stat">
					<span class="hero-stat-value">18</span>
					<span class="hero-stat-label">Comunas activas</span>
				</div>
				<div class="hero-stat">
					<span class="hero-stat-value">~24 min</span>
					<span class="hero-stat-label">Respuesta promedio</span>
				</div>
			</div>
		</div>
		<aside class="hero-panel hero-panel--map" aria-label="Mapa en vivo de paletiadas en Santiago">
			<div class="hero-panel-head">
				<p class="hero-panel-title">
					<span class="hero-live-dot" aria-hidden="true"></span>
					Paletiadas activas ahora
				</p>
				<span class="hero-panel-live">RM · en vivo</span>
			</div>
			<figure class="hero-map-wrap">
				<video
					class="hero-map-video"
					src="/videos/santiago-map.mp4"
					width="720"
					height="720"
					autoplay
					muted
					loop
					playsinline
					preload="metadata"
					aria-label="Simulación en mapa de Santiago: pedidas de viohs y Perkins en ruta por la Región Metropolitana"
				>
					Mapa de paletiadas activas en Santiago.
				</video>
				<figcaption class="hero-map-legend" aria-hidden="true">
					<span class="hero-map-legend-item hero-map-legend-item--pedida">Pedida</span>
					<span class="hero-map-legend-item hero-map-legend-item--perkin">Perkin</span>
				</figcaption>
			</figure>
			<p class="hero-panel-footer">
				<span class="hero-panel-check" aria-hidden="true">✓</span>
				Camila cumplió en Ñuñoa · hace 3 min · <strong class="hero-panel-kudos">perro bomba</strong>
			</p>
		</aside>
	</div>
</section>

<style>
	.hero :global(.section-phase) {
		margin-bottom: 1rem;
	}
</style>
