---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="es-CL">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="admin-shell">
		<header class="admin-header">
			<div class="container">
				<a href="/admin" style="color:#fff;font-weight:800;">Perkins Admin</a>
				<a href="/" style="color:rgba(255,255,255,0.7);">Ver sitio</a>
			</div>
		</header>
		<main class="container" style="padding: 2rem 1.25rem;">
			<nav class="admin-nav" aria-label="Admin">
				<a href="/admin" aria-current={path === '/admin' ? 'page' : undefined}>Overview</a>
				<a href="/admin/solicitudes" aria-current={path === '/admin/solicitudes' ? 'page' : undefined}>Ofertas</a>
				<a href="/admin/usuarios" aria-current={path === '/admin/usuarios' ? 'page' : undefined}>Usuarios</a>
				<a href="/admin/pagos" aria-current={path === '/admin/pagos' ? 'page' : undefined}>Pagos</a>
				<a href="/admin/planes" aria-current={path === '/admin/planes' ? 'page' : undefined}>Planes</a>
			</nav>
			<slot />
		</main>
		<script>
			import { initLogout } from '../scripts/logout.js';
			initLogout();
		</script>
	</body>
</html>
