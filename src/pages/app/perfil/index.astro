---
import AppLayout from '../../../layouts/AppLayout.astro';
import { hasRole, isPremiumPerkin, isPremiumRequester } from '../../../lib/roles';
import { COMUNAS_RM } from '../../../data/comunas';

const profile = Astro.locals.profile;
const onboard = Astro.url.searchParams.get('onboard');
---

<AppLayout title="Mi perfil · Perkins">
	<div class="grid-2">
		<div class="card">
			<h1>Mi perfil</h1>
			<p class="muted">{profile?.display_name} · {profile?.comuna}</p>
			<p>
				{hasRole(profile, 'requester') && hasRole(profile, 'perkin') && (
					<span>Traes y pides — el camino completo</span>
				)}
				{hasRole(profile, 'requester') && !hasRole(profile, 'perkin') && (
					<span>Vioh que pide</span>
				)}
				{hasRole(profile, 'perkin') && !hasRole(profile, 'requester') && (
					<span>Perkin que trae</span>
				)}
				{profile?.subscription_tier !== 'free' && (
					<span class="badge badge-premium">{profile?.subscription_tier}</span>
				)}
			</p>
			{hasRole(profile, 'perkin') && !hasRole(profile, 'requester') && (
				<p class="muted" style="margin-top:0.5rem;font-size:0.9rem;">
					Los Perkines aspiran a ser vioh. Sube la ficha trayendo bien — el ascenso es pasar de hacer a pedir.
				</p>
			)}
			{profile?.perkin_verified && <span class="badge badge-verified">Ficha máxima · verificado</span>}

			<form id="profile-form" class="inline" style="margin-top:1rem;">
				<label class="field">
					Nombre
					<input type="text" name="display_name" value={profile?.display_name ?? ''} required />
				</label>
				<label class="field">
					Teléfono
					<input type="tel" name="phone" value={profile?.phone ?? ''} required />
				</label>
				<label class="field">
					Comuna
					<select name="comuna">
						{COMUNAS_RM.map((c) => (
							<option value={c} selected={c === profile?.comuna}>{c}</option>
						))}
					</select>
				</label>
				<button type="submit" class="btn btn-primary btn-sm">Guardar</button>
			</form>
			<div id="profile-msg" class="alert success" hidden></div>
		</div>

		<div class="card">
			{hasRole(profile, 'perkin') && (
				<>
					<h2>Mercado Pago</h2>
					{profile?.mp_connected ? (
						<div class="alert success">Cuenta Mercado Pago conectada ✓</div>
					) : (
						<>
							<p class="muted">Conecta tu cuenta pa cobrar lucas como Perkin que trae.</p>
							{onboard === 'mp' && (
								<div class="alert info">Conecta Mercado Pago pa agarrar paletiadas y hacer lucas.</div>
							)}
							<a href="/api/mp/oauth/start" class="btn btn-primary">Conectar Mercado Pago</a>
						</>
					)}
				</>
			)}

			<h2 style="margin-top:1.5rem;">Suscripción</h2>
			<p class="muted">
				{isPremiumPerkin(profile) || isPremiumRequester(profile)
					? 'Tienes Premium activo — más ficha visible y mejores paletiadas.'
					: 'Premium te ayuda a destacar tu ficha y agarrar paletiadas con más lucas.'}
			</p>
			<a href="/precios" class="btn btn-outline btn-sm">Ver planes</a>

			{hasRole(profile, 'perkin') && (
				<div style="margin-top:1.5rem;">
					<h3>Tu ficha</h3>
					<p class="muted" style="margin-bottom:0.75rem;">Pega la misión, ponte la capa y cumple como perro bomba: preciso, real, leal, sincero y vioh.</p>
					<p>Misiones pegadas: {profile?.completed_count ?? 0}</p>
					<p><strong>Ficha:</strong> {(profile?.rating_avg ?? 0).toFixed(1)} / 5</p>
				</div>
			)}
		</div>
	</div>
</AppLayout>

<script>
	import { initProfilePage } from '../../../scripts/page-profile.js';
	initProfilePage();
</script>
